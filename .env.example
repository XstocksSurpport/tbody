# Mainnet JSON-RPC (Alchemy/Infura — recommended; public fallbacks are rate-limited).
NEXT_PUBLIC_MAINNET_RPC=

# Optional: direct ETH recipient when ThreeBody contract is not configured.
# Default built-in: 0xa8aE15A2aA06ad4e03f05E17cb61831c7Ce565a6
NEXT_PUBLIC_STELLAR_RECIPIENT=

# ThreeBody (Ethereum mainnet only) — on-chain mint + live progress.
# Deployed (mainnet): 0xf35Ad0Bc6E7bbeDFC2bc8AcB18864B74dFE3D547
NEXT_PUBLIC_THREEBODY_ADDRESS=0xf35Ad0Bc6E7bbeDFC2bc8AcB18864B74dFE3D547
# Must be 1 (Ethereum mainnet) for this app.
NEXT_PUBLIC_THREEBODY_CHAIN_ID=1

# --- Hardhat / deploy (local or CI, never commit .env) ---
# PRIVATE_KEY=
# MAINNET_RPC_URL=
# ETHERSCAN_API_KEY=
