# Optional: dedicated Ethereum mainnet RPC (falls back to public endpoints).
NEXT_PUBLIC_MAINNET_RPC=

# Optional override for Stellar Ignition recipient (mainnet). Default is built-in if unset.
NEXT_PUBLIC_STELLAR_RECIPIENT=

# ThreeBody contract — enables on-chain mint() + live mint progress bars (reads totalEthMinted, userStatus).
# Example Sepolia deploy:
# NEXT_PUBLIC_THREEBODY_ADDRESS=0xE9Dab7CE3299Fb733E025e295f704580fBD7C6D6
NEXT_PUBLIC_THREEBODY_ADDRESS=
# 1 = mainnet, 11155111 = Sepolia (must match where the contract is deployed).
NEXT_PUBLIC_THREEBODY_CHAIN_ID=11155111
# Optional faster Sepolia RPC if public endpoints rate-limit.
NEXT_PUBLIC_SEPOLIA_RPC=
