{
  "name": "3body",
  "private": true,
  "version": "3.0.0",
  "scripts": {
    "clean": "node -e \"try { require('fs').rmSync('.next', { recursive: true, force: true }); } catch (_) {}\"",
    "dev": "node ./node_modules/next/dist/bin/next dev -p 3000",
    "dev:clean": "npm run clean && node ./node_modules/next/dist/bin/next dev -p 3000",
    "dev:3001": "node ./node_modules/next/dist/bin/next dev -p 3001 -H 127.0.0.1",
    "dev:3001:clean": "npm run clean && node ./node_modules/next/dist/bin/next dev -p 3001 -H 127.0.0.1",
    "prebuild": "npm run lint",
    "build": "node ./node_modules/next/dist/bin/next build",
    "start": "node ./node_modules/next/dist/bin/next start -p 3000",
    "start:3001": "node ./node_modules/next/dist/bin/next start -p 3001 -H 127.0.0.1",
    "lint": "node ./node_modules/typescript/bin/tsc --noEmit",
    "verify": "npm run clean && npm run build"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.59.0",
    "framer-motion": "^11.11.17",
    "gsap": "^3.12.5",
    "next": "^15.0.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "three": "^0.170.0",
    "viem": "^2.21.0",
    "wagmi": "^2.12.0"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^7.0.0",
    "@types/node": "^22.9.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/three": "^0.170.0",
    "autoprefixer": "^10.4.20",
    "hardhat": "^3.4.5",
    "javascript-obfuscator": "^5.4.2",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.15",
    "typescript": "^5.6.3",
    "webpack-obfuscator": "^3.6.1"
  }
}
